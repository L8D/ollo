{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ollo session-tracker set-attention \"$KOTA_CURRENT_TICKET_ID\"",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ollo session-tracker set-attention \"$KOTA_CURRENT_TICKET_ID\"",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "ollo backup-plan-on-exit"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "ollo session-tracker set-attention \"$KOTA_CURRENT_TICKET_ID\"",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ollo sync-description-on-prompt"
          }
        ]
      }
    ]
  }
}
