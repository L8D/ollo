{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ollo emit-hook-event Stop",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ollo emit-hook-event PermissionRequest",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ollo emit-hook-event SessionStart",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "ollo backup-plan-on-exit"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "ollo emit-hook-event PreToolUse",
            "async": true
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "ollo emit-hook-event PreToolUse",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ollo sync-description-on-prompt"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "ollo emit-hook-event UserPromptSubmit",
            "async": true
          }
        ]
      }
    ]
  }
}
